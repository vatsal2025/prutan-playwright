{
  "name": "playwright-prutan",
  "version": "1.0.0",
  "description": "Playwright E2E test framework for PruTAN — Python engine & Java Desktop",
  "scripts": {
    "test": "playwright test",
    "test:python": "playwright test --project=python-engine",
    "test:desktop": "playwright test --project=java-desktop",
    "test:ui": "playwright test --project=python-engine tests/cloud",
    "test:modules": "playwright test --project=python-engine --ignore-snapshots tests/studio tests/sandbox tests/interceptor tests/trace tests/stresslab tests/wiso",
    "test:smoke": "playwright test --grep @smoke",
    "test:studio": "playwright test tests/studio",
    "test:sandbox": "playwright test tests/sandbox",
    "test:interceptor": "playwright test tests/interceptor",
    "test:trace": "playwright test tests/trace",
    "test:stresslab": "playwright test tests/stresslab",
    "test:wiso": "playwright test tests/wiso",
    "report": "playwright show-report",
    "codegen": "playwright codegen"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "dotenv": "^16.4.0"
  }
}
