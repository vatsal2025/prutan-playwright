# ═══════════════════════════════════════════════════════════════════════════
#  PruTAN Playwright — per-user .env template
#  Copy this file to .env and fill in YOUR credentials.
#  .env is git-ignored — never commit real credentials.
# ═══════════════════════════════════════════════════════════════════════════

# ── PruTAN Web (Python Engine + all cloud UI tests) ──────────────────────────
# Same application — one set of credentials covers both module tests AND the
# comprehensive UI tests in tests/cloud/
PYTHON_ENGINE_URL=http://13.233.206.245:8080
PYTHON_ENGINE_USER=your_email@example.com
PYTHON_ENGINE_PASS=your_password

# ── Java Desktop (Electron via CDP) ──────────────────────────────────────────
# Start Prutan.exe with: --remote-debugging-port=9222
DESKTOP_CDP_URL=http://localhost:9222
DESKTOP_BASE_URL=http://localhost:59140
DESKTOP_USER=your_email@example.com

# ── Optional ──────────────────────────────────────────────────────────────────
JAVA_REF_URL=https://app.prutan.com
QA_TEAM_GUID=
