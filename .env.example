# ═══════════════════════════════════════════════════════════════════════════
#  PruTAN Playwright — per-user .env template
#  Copy this file to .env and fill in YOUR credentials.
#  .env is git-ignored — never commit real credentials.
# ═══════════════════════════════════════════════════════════════════════════

# ── Python Engine ────────────────────────────────────────────────────────────
# Shared server URL — change only if your instance differs
PYTHON_ENGINE_URL=http://13.233.206.245:8080

# YOUR login credentials for the python engine
PYTHON_ENGINE_USER=your_email@example.com
PYTHON_ENGINE_PASS=your_password

# ── Java Desktop (Electron via CDP) ──────────────────────────────────────────
# Start Prutan.exe with: --remote-debugging-port=9222
# These defaults work for standard installs — change if your app uses different ports
DESKTOP_CDP_URL=http://localhost:9222
DESKTOP_BASE_URL=http://localhost:59140

# Your login email on the desktop app (used for re-login flows)
DESKTOP_USER=your_email@example.com

# ── PruTAN Cloud (https://app.prutan.com) ────────────────────────────────────
# YOUR credentials for app.prutan.com — required to run cloud tests authenticated
PRUTAN_CLOUD_URL=https://app.prutan.com
PRUTAN_CLOUD_USER=your_email@example.com
PRUTAN_CLOUD_PASS=your_password

# ── Optional / Advanced ───────────────────────────────────────────────────────
# Java reference URL (used in some assertion helpers)
JAVA_REF_URL=https://app.prutan.com

# QA Team GUID — used when scoping requests to a specific workspace
QA_TEAM_GUID=
